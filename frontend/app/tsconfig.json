{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "outDir": "build/out",
        "isolatedModules": true,
        "tsBuildInfoFile": null,
        "paths": {
            "@src/*": ["./src/*"],
            "@actions/*": ["./src/actions/*"],
            "@i18n/*": ["./src/i18n/*"],
            "@stores/*": ["./src/stores/*"],
            "@theme/*": ["./src/theme/*"],
            "@utils/*": ["./src/utils/*"],
            "@styles/*": ["./src/styles/*"],
            "@webcomponents/*": ["./src/web-components/*"],
            "@component-lib/*": ["../component-lib/src/*"],
            "@shared": ["../openchat-shared/src/index.ts"],
            "@shared/*": ["../openchat-shared/src/*"],
            "@client": ["../openchat-client/src/index.ts"],
            "@client/*": ["../openchat-client/src/*"],
            "@agent": ["../openchat-agent/src/index.ts"],
            "@agent/*": ["../openchat-agent/src/*"],
            "@worker": ["../openchat-worker/src/worker.ts"],
            "@worker/*": ["../openchat-worker/src/*"],
            "tauri-plugin-oc-api": ["../tauri-plugin-oc/guest-js/index.ts"],
            "tauri-plugin-oc-api/*": ["../tauri-plugin-oc/guest-js/*"]
        }
    },
    "include": [
        "./src/**/*",
        "../vite-env.d.ts",
        "../global.d.ts",
        "../node_modules/component-lib/src/**/*.ts"
    ],
    "exclude": ["build/**/*", "node_modules"]
}
