{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "OpenChat",
    "version": "0.1.0",
    "identifier": "com.oc.app",
    "build": {
        "frontendDist": "../app/build",
        "devUrl": "http://localhost:5003",
        "beforeDevCommand": "echo 'run dev server'",
        "beforeBuildCommand": "echo 'build dev server'"
    },
    "app": {
        "windows": [],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": ["**"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "deep-link": {
            "mobile": [{ "schema": "openchat", "host": "oc.app" }]
        }
    }
}
