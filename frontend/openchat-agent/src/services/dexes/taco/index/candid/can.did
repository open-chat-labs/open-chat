// Trimmed candid for the TACO exchange — only the slice OpenChat queries to
// list pools. Full canister exposed at:
// https://dashboard.internetcomputer.org/canister/qioex-5iaaa-aaaan-q52ba-cai

type AMMPool = record {
  token0: text;
  token1: text;
  reserve0: nat;
  reserve1: nat;
  price0: float64;
  price1: float64;
  totalLiquidity: nat;
};

service : {
  getAllAMMPools: () -> (vec AMMPool) query;
}
